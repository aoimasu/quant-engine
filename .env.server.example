# QE-427: environment for docker-compose.server.yml (the qe-server admin image).
# Copy to `.env.server` and fill in. Do NOT commit the filled-in file.
#
#   cp .env.server.example .env.server
#   docker compose --env-file .env.server -f docker-compose.server.yml up --build

# REQUIRED. HMAC key for signing session cookies. The container binds 0.0.0.0 (non-loopback), so
# without this the server refuses to boot (QE-409 fail-closed). Generate with: openssl rand -hex 32
QE_SESSION_SECRET=

# Google OAuth client (QE-256).
QE_OAUTH_GOOGLE_CLIENT_ID=
QE_OAUTH_GOOGLE_CLIENT_SECRET=
# The PUBLIC https URL of the callback (TLS terminated at the fronting proxy — QE-427). Using https
# here makes session cookies `Secure` (QE-409). Example: https://admin.example.com/api/auth/callback
QE_OAUTH_REDIRECT_URI=

# Comma-separated sign-in allowlist (QE-256). Empty => nobody can sign in (fails closed).
QE_ADMIN_ALLOWED_EMAILS=

# Optional: code-commit provenance stamped into the image (QE-420). e.g. $(git rev-parse --short=12 HEAD)
QE_CODE_COMMIT=
