# qe-server environment — copy this file to `.env` and fill in real values.
#   cp .env.example .env
# `qe-server` loads `.env` on startup (dotenvy). Real process env vars ALWAYS take precedence over
# `.env`. `.env` is gitignored and must NEVER be committed (it holds real secrets); this file must
# stay placeholder-only.

# --- Admin UI: static assets ------------------------------------------------------------------------
# Directory the compiled admin-UI front-end is served from.
QE_SERVER_STATIC_DIR=web/dist
#
# STORAGE: leave it at the qe-config defaults (data/lmdb/{market,synthetic} + data/artifacts). The
# server derives its read dirs from qe-config and pins the SAME config onto the CLI jobs it spawns, so
# both agree and it boots; read APIs are just empty until data is ingested.
#
# Do NOT set a single QE_STORAGE__MARKET_DIR here: with no config.toml present, qe-config builds the
# [storage] table from env alone and then requires ALL of market/synthetic/artifacts (StorageConfig
# has no per-field default) — so a lone override fails with "missing field synthetic_dir". And the
# deprecated QE_SERVER_MARKET_DIR refuses boot when it diverges from the CLI's store (QE-419).
#
# To read the committed sample store OFFLINE, use a config file (both server + CLI read it):
#   cp config.example.toml config.toml
#   # then set  [storage] market_dir = "crates/cli/tests/fixtures/sample_store"  in config.toml

# --- Google OAuth sign-in ---------------------------------------------------------------------------
# Comma-separated allowlist of emails permitted to sign in (fails closed when empty).
QE_ADMIN_ALLOWED_EMAILS=you@example.com
# Google OAuth client credentials (from the Google Cloud console).
QE_GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
QE_GOOGLE_CLIENT_SECRET=replace-me
# OAuth redirect URI; must match the console entry. Loopback default for local dev.
QE_GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/auth/callback

# --- Governance (optional) --------------------------------------------------------------------------
# Comma-separated role allowlists for the seal/approve governance flow (fail closed when unset).
QE_ROLE_OPERATORS=you@example.com
QE_ROLE_APPROVERS=you@example.com
QE_ROLE_ADMINS=you@example.com
# Persistent HMAC key that enables production-seal capability (disabled/fail-closed when unset).
QE_AUDIT_SIGNING_KEY=replace-me
